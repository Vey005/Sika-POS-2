# SikaPOS Cloud Server Configuration
# Copy to .env and fill in values

PORT=3000

# Database (PostgreSQL)
DATABASE_URL=postgresql://postgres:sikapos123@db:5432/sikapos_cloud

# JWT Secret (generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))")
JWT_SECRET=

# PIN Salt (keep secret, used to hash user PINs from desktop app)
PIN_SALT=

# Portal Admin Credentials
PORTAL_ADMIN_USER=big admin
PORTAL_ADMIN_PASS_HASH=
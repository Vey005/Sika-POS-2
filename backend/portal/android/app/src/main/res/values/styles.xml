<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme -->
    <style name="AppTheme" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="colorPrimary">#D4A017</item>
        <item name="colorPrimaryDark">#0C0C0F</item>
        <item name="colorAccent">#D4A017</item>
        <item name="android:windowBackground">#0C0C0F</item>
        <item name="android:statusBarColor">#0C0C0F</item>
        <item name="android:navigationBarColor">#0C0C0F</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:windowLightNavigationBar" xmlns:tools="http://schemas.android.com/tools" tools:targetApi="o_mr1">false</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:windowBackground">#0C0C0F</item>
        <item name="android:statusBarColor">#0C0C0F</item>
        <item name="android:navigationBarColor">#0C0C0F</item>
        <item name="android:windowLightStatusBar">false</item>
    </style>

    <!-- Splash screen theme — uses our branded drawable -->
    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <item name="android:windowBackground">@drawable/splash</item>
        <item name="android:statusBarColor">#0C0C0F</item>
        <item name="android:navigationBarColor">#0C0C0F</item>
    </style>

</resources>